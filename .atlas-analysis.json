  "keyFeatures": [
    "JWT-based user authentication with bcrypt password hashing",
    "Vehicle browsing with filtering by type, capacity, and availability",
    "Real-time booking system with date validation and price calculation",
    "User dashboard for managing active and past rentals",
    "Responsive React frontend with Framer Motion animations",
    "Automated rental expiration handling"
  ],
  "publicApiSurface": [
    "POST /api/user/register - Register new user",
    "POST /api/user/login - Authenticate user",
    "GET /api/user - Get authenticated user profile",
    "GET /api/vehicles - List all available vehicles",
    "GET /api/vehicles/:id - Get vehicle details",
    "POST /api/book-ride/:car_id - Book a car rental",
    "POST /api/cancel-ride/:car_id - Cancel active rental",
    "GET /api/cancel-expired-rentals - Expire outdated rentals"
  ]
}
